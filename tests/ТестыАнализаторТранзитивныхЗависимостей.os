&Тест
Процедура ТестДолжен_ПроверятьОдинПакетОтдельноДляProdИDevВеток() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета()
		.Добавить("branch_prod_root", "1.0.0")
		.ДобавитьДляРазработки("branch_dev_root", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(2);

	КонфликтProd = НайтиЕдинственныйКонфликт(
		Конфликты,
		"branch_leaf",
		Ложь,
		ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию
	);
	Ожидаем.Что(КонфликтProd.ИсточникТребования).Равно("branch_common_parent");
	Ожидаем.Что(КонфликтProd.ЦепочкаЗависимостей).Равно("branch_prod_root -> branch_common_parent -> branch_leaf");

	КонфликтDev = НайтиЕдинственныйКонфликт(
		Конфликты,
		"branch_leaf",
		Истина,
		ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию
	);
	Ожидаем.Что(КонфликтDev.ИсточникТребования).Равно("branch_common_parent");
	Ожидаем.Что(КонфликтDev.ЦепочкаЗависимостей).Равно("branch_dev_root -> branch_common_parent -> branch_leaf");

КонецПроцедуры

