Функция УстановленныеПакетыДляПроекта()

	КаталогБиблиотек = ФС.ПолныйПуть("./tests/fixtures/ПроектСТранзитивнымиКонфликтами/oscript_modules");

	Результат = Новый Соответствие();
	Результат.Вставить("root_a", ОбъединитьПути(КаталогБиблиотек, "root_a"));
	Результат.Вставить("root_b", ОбъединитьПути(КаталогБиблиотек, "root_b"));
	Результат.Вставить("root_self", ОбъединитьПути(КаталогБиблиотек, "root_self"));
	Результат.Вставить("root_cycle_a", ОбъединитьПути(КаталогБиблиотек, "root_cycle_a"));
	Результат.Вставить("root_cycle_b", ОбъединитьПути(КаталогБиблиотек, "root_cycle_b"));
	Результат.Вставить("root_missing", ОбъединитьПути(КаталогБиблиотек, "root_missing"));
	Результат.Вставить("root_missing_alt", ОбъединитьПути(КаталогБиблиотек, "root_missing_alt"));
	Результат.Вставить("root_level_a", ОбъединитьПути(КаталогБиблиотек, "root_level_a"));
	Результат.Вставить("root_level_b", ОбъединитьПути(КаталогБиблиотек, "root_level_b"));
	Результат.Вставить("level_deep_parent", ОбъединитьПути(КаталогБиблиотек, "level_deep_parent"));
	Результат.Вставить("root_repeat_a", ОбъединитьПути(КаталогБиблиотек, "root_repeat_a"));
	Результат.Вставить("root_repeat_b", ОбъединитьПути(КаталогБиблиотек, "root_repeat_b"));
	Результат.Вставить("shared_parent", ОбъединитьПути(КаталогБиблиотек, "shared_parent"));
	Результат.Вставить("shared", ОбъединитьПути(КаталогБиблиотек, "shared"));
	Результат.Вставить("duplicate_parent", ОбъединитьПути(КаталогБиблиотек, "duplicate_parent"));
	Результат.Вставить("duplicate_dev_root", ОбъединитьПути(КаталогБиблиотек, "duplicate_dev_root"));
	Результат.Вставить("duplicate_leaf", ОбъединитьПути(КаталогБиблиотек, "duplicate_leaf"));
	Результат.Вставить("branch_prod_root", ОбъединитьПути(КаталогБиблиотек, "branch_prod_root"));
	Результат.Вставить("branch_dev_root", ОбъединитьПути(КаталогБиблиотек, "branch_dev_root"));
	Результат.Вставить("branch_common_parent", ОбъединитьПути(КаталогБиблиотек, "branch_common_parent"));
	Результат.Вставить("branch_leaf", ОбъединитьПути(КаталогБиблиотек, "branch_leaf"));
	Результат.Вставить("boundary_root", ОбъединитьПути(КаталогБиблиотек, "boundary_root"));
	Результат.Вставить("boundary_min_leaf", ОбъединитьПути(КаталогБиблиотек, "boundary_min_leaf"));
	Результат.Вставить("boundary_max_leaf", ОбъединитьПути(КаталогБиблиотек, "boundary_max_leaf"));

	Возврат Результат;

КонецФункции

Функция НайтиЕдинственныйКонфликт(Конфликты, ИмяПакета, ДляРазработки, ТипКонфликта)

	Отбор = Новый Структура(
		"ИмяПакета, ДляРазработки, ТипКонфликта",
		ИмяПакета,
		ДляРазработки,
		ТипКонфликта
	);

	НайденныеКонфликты = Конфликты.НайтиСтроки(Отбор);
	Ожидаем.Что(НайденныеКонфликты).ИмеетДлину(1);

	Возврат НайденныеКонфликты[0];

КонецФункции
