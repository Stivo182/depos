#Использовать "helpers"

&Тест
Процедура ТестДолжен_НайтиНесоответствиеУстановленнойВерсииТранзитивномуТребованию() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета().Добавить("root_a", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(1);
	Ожидаем.Что(Конфликты[0].ИмяПакета).Равно("shared");
	Ожидаем.Что(Конфликты[0].ДляРазработки).ЭтоЛожь();
	Ожидаем.Что(Конфликты[0].ТипКонфликта).Равно(ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию);
	Ожидаем.Что(Конфликты[0].ИсточникТребования).Равно("root_a");
	Ожидаем.Что(Конфликты[0].ТребуемаяВерсия).Равно(">=2.0.0");
	Ожидаем.Что(Конфликты[0].УстановленнаяВерсия).Равно("1.5.0");
	Ожидаем.Что(Конфликты[0].ЦепочкаЗависимостей).Равно("root_a -> shared");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НеДублироватьОдинаковыйКонфликтУстановленнойВерсииИзРазныхПутей() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета()
		.Добавить("duplicate_parent", "1.0.0")
		.ДобавитьДляРазработки("duplicate_dev_root", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(1);
	Ожидаем.Что(Конфликты[0].ИмяПакета).Равно("duplicate_leaf");
	Ожидаем.Что(Конфликты[0].ДляРазработки).ЭтоИстина();
	Ожидаем.Что(Конфликты[0].ТипКонфликта).Равно(ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию);
	Ожидаем.Что(Конфликты[0].ИсточникТребования).Равно("duplicate_parent");
	Ожидаем.Что(Конфликты[0].ТребуемаяВерсия).Равно(">=2.0.0");
	Ожидаем.Что(Конфликты[0].УстановленнаяВерсия).Равно("1.0.0");
	Ожидаем.Что(Конфликты[0].ЦепочкаЗависимостей).Равно("duplicate_parent -> duplicate_leaf");

КонецПроцедуры

