&Тест
Процедура ТестДолжен_НайтиНесовместимыеТребованияРазныхВеток() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета()
		.Добавить("root_a", "1.0.0")
		.Добавить("root_b", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());
	Конфликты.Сортировать("ТипКонфликта, ИсточникТребования");

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(3);
	Ожидаем.Что(Конфликты.ВыгрузитьКолонку("ТипКонфликта")).Содержит(ТипыКонфликтовЗависимостей.НесовместимыеТребования);
	Ожидаем.Что(Конфликты.ВыгрузитьКолонку("ТипКонфликта")).Содержит(ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию);

	НесовместимыйКонфликт = Конфликты.Найти(ТипыКонфликтовЗависимостей.НесовместимыеТребования, "ТипКонфликта");
	Ожидаем.Что(НесовместимыйКонфликт.ИмяПакета).Равно("shared");
	Ожидаем.Что(НесовместимыйКонфликт.ИсточникТребования).Равно("root_a, root_b");
	Ожидаем.Что(НесовместимыйКонфликт.ТребуемаяВерсия).Равно(">=2.0.0; <=1.0.0");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НайтиНеустановленнуюТранзитивнуюЗависимость() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета().Добавить("root_missing", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(1);
	Ожидаем.Что(Конфликты[0].ИмяПакета).Равно("missing_shared");
	Ожидаем.Что(Конфликты[0].ДляРазработки).ЭтоЛожь();
	Ожидаем.Что(Конфликты[0].ТипКонфликта).Равно(ТипыКонфликтовЗависимостей.ТранзитивнаяЗависимостьНеУстановлена);
	Ожидаем.Что(Конфликты[0].ИсточникТребования).Равно("root_missing");
	Ожидаем.Что(Конфликты[0].ТребуемаяВерсия).Равно(">=1.0.0");
	Ожидаем.Что(Конфликты[0].УстановленнаяВерсия).Равно("");
	Ожидаем.Что(Конфликты[0].ЦепочкаЗависимостей).Равно("root_missing -> missing_shared");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НайтиНесовместимыеТребованияКНеустановленнойТранзитивнойЗависимости() Экспорт

	// Подготовка
	Анализатор = Новый АнализаторТранзитивныхЗависимостей();
	Зависимости = Новый ЗависимостиПакета()
		.Добавить("root_missing", "1.0.0")
		.Добавить("root_missing_alt", "1.0.0");

	// Действие
	Конфликты = Анализатор.Проверить(Зависимости, УстановленныеПакетыДляПроекта());

	// Проверка
	Ожидаем.Что(Конфликты).ИмеетДлину(3);

	НесовместимыйКонфликт = Конфликты.Найти(ТипыКонфликтовЗависимостей.НесовместимыеТребования, "ТипКонфликта");
	Ожидаем.Что(НесовместимыйКонфликт.ИмяПакета).Равно("missing_shared");
	Ожидаем.Что(НесовместимыйКонфликт.ИсточникТребования).Равно("root_missing, root_missing_alt");
	Ожидаем.Что(НесовместимыйКонфликт.ТребуемаяВерсия).Равно(">=1.0.0; <=0.5.0");
	Ожидаем.Что(НесовместимыйКонфликт.УстановленнаяВерсия).Равно("");

КонецПроцедуры

