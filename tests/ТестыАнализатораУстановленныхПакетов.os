
// BSLLS:MagicNumber-off
// BSLLS:LineLength-off
// BSLLS:DuplicateStringLiteral-off

#Использовать "helpers"

Перем _Поделка; // Поделка
Перем _ПеременныеСредыКонфигурация; // Строка

&Инициализация
Процедура Инициализация() Экспорт

	_Поделка = Новый Поделка();
	_Поделка.ЗапуститьПриложение();

	_ПеременныеСредыКонфигурация = ПолучитьПеременнуюСреды("OSCRIPT_CONFIG");

КонецПроцедуры

&После
Процедура ПослеКаждого() Экспорт
	УстановитьПеременнуюСреды("OSCRIPT_CONFIG", _ПеременныеСредыКонфигурация);
КонецПроцедуры

&Тест
Процедура ТестДолжен_НайтиНеустановленныеПакеты() Экспорт
	
	// Подготовка
	ЗаглушитьТекущиеКаталогиБиблиотек();

	Анализатор = _Поделка.НайтиЖелудь("АнализаторЗависимостей")
		.РабочийКаталог("./tests/fixtures");

	Зависимости = ПолучитьЗависимостиПоУмолчанию();

	// Действие
	Результат = Анализатор.ПроверитьЗависимости(Зависимости);

	// Проверка
	Пакеты = Результат.НеустановленныеПакеты.ВыгрузитьКолонку("ИмяПакета");

	Ожидаем.Что(Пакеты).ИмеетДлину(3);
	Ожидаем.Что(Пакеты).Содержит("asserts");
	Ожидаем.Что(Пакеты).Содержит("packageinfo");
	Ожидаем.Что(Пакеты).Содержит("semver");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НайтиКонфликтыВерсий() Экспорт
	
	// Подготовка
	ЗаглушитьТекущиеКаталогиБиблиотек();

	Анализатор = _Поделка.НайтиЖелудь("АнализаторЗависимостей")
		.РабочийКаталог("./tests/fixtures");

	Зависимости = ПолучитьЗависимостиПоУмолчанию();

	// Действие
	Результат = Анализатор.ПроверитьЗависимости(Зависимости);

	// Проверка
	КонфликтыВерсий = Результат.КонфликтыВерсийУстановленныхПакетов;
	КонфликтыВерсий.Сортировать("ИмяПакета");

	Ожидаем.Что(КонфликтыВерсий).ИмеетДлину(3);

	Ожидаем.Что(КонфликтыВерсий[0].ИмяПакета).Равно("1testrunner");
	Ожидаем.Что(КонфликтыВерсий[0].ДляРазработки).Равно(Истина);
	Ожидаем.Что(КонфликтыВерсий[0].ТребуемаяВерсия).Равно(">=1.8.0");
	Ожидаем.Что(КонфликтыВерсий[0].УстановленнаяВерсия).Равно("1.7.0");

	Ожидаем.Что(КонфликтыВерсий[1].ИмяПакета).Равно("annotations");
	Ожидаем.Что(КонфликтыВерсий[1].ДляРазработки).Равно(Ложь);
	Ожидаем.Что(КонфликтыВерсий[1].ТребуемаяВерсия).Равно(">=1.3.0");
	Ожидаем.Что(КонфликтыВерсий[1].УстановленнаяВерсия).Равно("1.0.0");
	
	Ожидаем.Что(КонфликтыВерсий[2].ИмяПакета).Равно("autumn");
	Ожидаем.Что(КонфликтыВерсий[2].ДляРазработки).Равно(Ложь);
	Ожидаем.Что(КонфликтыВерсий[2].ТребуемаяВерсия).Равно(">=3.2.0,<=4.4.1");
	Ожидаем.Что(КонфликтыВерсий[2].УстановленнаяВерсия).Равно("5.0.0");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НайтиКонфликтыТранзитивныхЗависимостей() Экспорт

	// Подготовка
	ЗаглушитьТекущиеКаталогиБиблиотек();

	Анализатор = _Поделка.НайтиЖелудь("АнализаторЗависимостей")
		.РабочийКаталог("./tests/fixtures/ПроектСТранзитивнымиКонфликтами");

	Зависимости = Новый ЗависимостиПакета()
		.ЗаполнитьИзМанифеста("./tests/fixtures/ПроектСТранзитивнымиКонфликтами/packagedef");

	// Действие
	Результат = Анализатор.ПроверитьЗависимости(Зависимости);

	// Проверка
	Конфликты = Результат.КонфликтыТранзитивныхЗависимостей;
	Конфликты.Сортировать("ТипКонфликта, ИмяПакета, ИсточникТребования");

	Ожидаем.Что(Конфликты).ИмеетДлину(4);

	ПроверитьТранзитивныйКонфликт(
		Конфликты[0],
		"shared",
		ТипыКонфликтовЗависимостей.НесовместимыеТребования,
		"root_a, root_b",
		">=2.0.0; <=1.0.0",
		"1.5.0",
		"root_a -> shared; root_b -> shared"
	);
	ПроверитьТранзитивныйКонфликт(
		Конфликты[1],
		"missing_shared",
		ТипыКонфликтовЗависимостей.ТранзитивнаяЗависимостьНеУстановлена,
		"root_missing",
		">=1.0.0",
		"",
		"root_missing -> missing_shared"
	);
	ПроверитьТранзитивныйКонфликт(
		Конфликты[2],
		"shared",
		ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию,
		"root_a",
		">=2.0.0",
		"1.5.0",
		"root_a -> shared"
	);
	ПроверитьТранзитивныйКонфликт(
		Конфликты[3],
		"shared",
		ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию,
		"root_b",
		"<=1.0.0",
		"1.5.0",
		"root_b -> shared"
	);

КонецПроцедуры

Процедура ПроверитьТранзитивныйКонфликт(
	Конфликт,
	ИмяПакета,
	ТипКонфликта,
	ИсточникТребования,
	ТребуемаяВерсия,
	УстановленнаяВерсия,
	ЦепочкаЗависимостей
)

	Ожидаем.Что(Конфликт.ИмяПакета).Равно(ИмяПакета);
	Ожидаем.Что(Конфликт.ДляРазработки).ЭтоЛожь();
	Ожидаем.Что(Конфликт.ТипКонфликта).Равно(ТипКонфликта);
	Ожидаем.Что(Конфликт.ИсточникТребования).Равно(ИсточникТребования);
	Ожидаем.Что(Конфликт.ТребуемаяВерсия).Равно(ТребуемаяВерсия);
	Ожидаем.Что(Конфликт.УстановленнаяВерсия).Равно(УстановленнаяВерсия);
	Ожидаем.Что(Конфликт.ЦепочкаЗависимостей).Равно(ЦепочкаЗависимостей);

КонецПроцедуры

Функция ПолучитьЗависимостиПоУмолчанию()
	Возврат Новый ЗависимостиПакета().ЗаполнитьИзМанифеста("./tests/fixtures/packagedef");
КонецФункции

Процедура ЗаглушитьТекущиеКаталогиБиблиотек()
	
	Параметры = Новый Массив();
	Параметры.Добавить("lib.system=./nonexistent");
	Параметры.Добавить("lib.additional=./nonexistent");

	УстановитьПеременнуюСреды("OSCRIPT_CONFIG", СтрСоединить(Параметры, ";"));

КонецПроцедуры
