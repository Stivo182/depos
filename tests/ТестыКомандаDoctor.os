&Тест
Процедура ТестДолжен_ПроверитьИгнорированиеЗависимостейДляРазработки() Экспорт

	// Подготовка
	ОжидаемыйВывод1 = 
	"Найдено проблем: 8
	|  4 отсутствуют в манифесте
	|  2 не используются
	|  1 не установлен
	|  1 конфликт версий
	|
	|[1] Отсутствуют в манифесте
	|
	|   missing_manifests_present_src
	|      └─ %1\src\Классы\Класс1.os
	|   missing_manifests_present_src_tests
	|      ├─ %1\src\Классы\Класс1.os
	|      └─ %1\src\Классы\Класс2.os
	|   present_in_dev_src_missing_tests
	|      └─ %1\src\Классы\Класс1.os
	|   present_in_dev_src_tests
	|      └─ %1\src\Классы\Класс1.os
	|
	|[2] Объявлены, но не используются
	|
	|   present_in_prod_missing_src_tests
	|   present_in_prod_tests_missing_src
	|
	|[3] Не установлены
	|
	|   present_in_prod_missing_src_tests
	|
	|[4] Несоответствие версий";

	ОжидаемыйВывод2 =
	"[4] Несоответствие версий
	|
	|   present_in_prod_tests_missing_src
	|     установлена: 1.0.0
	|     требуется:   >=1.1.0
	|     путь:        %1\oscript_modules\present_in_prod_tests_missing_src";

	ПодготовитьОжидаемыйВывод(ОжидаемыйВывод1);
	ПодготовитьОжидаемыйВывод(ОжидаемыйВывод2);

	Поделка = ПомощникТестирования.ОтладочнаяПоделка();
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("doctor");
	ПараметрыКоманды.Добавить("--manifest");
	ПараметрыКоманды.Добавить("./tests/fixtures/ПроектДляАнализа/packagedef");
	ПараметрыКоманды.Добавить("--ignore-dev");

	// Действие
	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Проверка
	ТекстВывода = ПомощникТестирования.ПолучитьТекстИзПотокаВывода(ПотокВывода);

	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВывод1);
	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВывод2);
	Ожидаем.Что(ТекстВывода).Содержит("Найдено проблем: 8");

КонецПроцедуры

&Тест
Процедура ТестДолжен_ПолучитьРезультатаАнализаМанифестаПоИмениПакета() Экспорт

	// Подготовка
	УстановитьТекущийКаталог("./tests/fixtures");
	УстановитьПеременнуюСреды(
		"OSCRIPT_CONFIG",
		"lib.system=" + ФС.ПолныйПуть(ОбъединитьПути(ТекущийКаталог, "tests/fixtures/oscript_modules"))
	);

	Поделка = ПомощникТестирования.ОтладочнаяПоделка();
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("doctor");
	ПараметрыКоманды.Добавить("--package");
	ПараметрыКоманды.Добавить("mypackage");

	// Действие
	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Проверка
	ТекстВывода = ПомощникТестирования.ПолучитьТекстИзПотокаВывода(ПотокВывода);

	Ожидаем.Что(ТекстВывода).Содержит("[1] Объявлены, но не используются");
	Ожидаем.Что(ТекстВывода).Содержит("Несоответствие версий");
	Ожидаем.Что(ТекстВывода).Не_().Содержит("   1testrunner (dev)");

КонецПроцедуры

