&Тест
Процедура ТестДолжен_ВывестиКонфликтыТранзитивныхЗависимостей() Экспорт

	// Подготовка
	ОжидаемыйВыводНесовместимыеТребования =
	"     причина:     несовместимые требования
	|     установлена: 1.5.0
	|     требуется:   >=2.0.0; <=1.0.0
	|     источники:   root_a, root_b
	|     цепочки:
	|       ├─ root_a -> shared
	|       └─ root_b -> shared";

	ОжидаемыйВыводНеустановленнаяЗависимость =
	"   missing_shared
	|     причина:     транзитивная зависимость не установлена
	|     требуется:   >=1.0.0
	|     источник:    root_missing
	|     цепочка:     root_missing -> missing_shared";

	ОжидаемыйВыводНесоответствиеRootA =
	"     источник:    root_a
	|     цепочка:     root_a -> shared";

	ОжидаемыйВыводНесоответствиеRootB =
	"     источник:    root_b
	|     цепочка:     root_b -> shared";

	Поделка = ПомощникТестирования.ОтладочнаяПоделка();
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("doctor");
	ПараметрыКоманды.Добавить("--manifest");
	ПараметрыКоманды.Добавить("./tests/fixtures/ПроектСТранзитивнымиКонфликтами/packagedef");

	// Действие
	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Проверка
	ТекстВывода = ПомощникТестирования.ПолучитьТекстИзПотокаВывода(ПотокВывода);

	Ожидаем.Что(ТекстВывода).Содержит("[1] Объявлены, но не используются");
	Ожидаем.Что(ТекстВывода).Содержит("[2] Конфликты транзитивных зависимостей");
	Ожидаем.Что(ТекстВывода).Содержит("4 конфликта транзитивных зависимостей");
	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВыводНесовместимыеТребования);
	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВыводНеустановленнаяЗависимость);
	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВыводНесоответствиеRootA);
	Ожидаем.Что(ТекстВывода).Содержит(ОжидаемыйВыводНесоответствиеRootB);
	Ожидаем.Что(ТекстВывода).Содержит("Найдено проблем: 7");

КонецПроцедуры

&Тест
Процедура ТестДолжен_НеДублироватьОдинаковыйТранзитивныйКонфликтВВыводе() Экспорт

	// Подготовка
	Поделка = ПомощникТестирования.ОтладочнаяПоделка();
	КонсольноеПриложение = Поделка.НайтиЖелудь("КонсольноеПриложение");

	ПараметрыКоманды = Новый Массив();
	ПараметрыКоманды.Добавить("doctor");
	ПараметрыКоманды.Добавить("--manifest");
	ПараметрыКоманды.Добавить("./tests/fixtures/ПроектСТранзитивнымиКонфликтами/packagedef-duplicate-dev");

	// Действие
	КонсольноеПриложение.Запустить(ПараметрыКоманды);

	// Проверка
	ТекстВывода = ПомощникТестирования.ПолучитьТекстИзПотокаВывода(ПотокВывода);

	Ожидаем.Что(ТекстВывода).Содержит("1 конфликт транзитивных зависимостей");
	Ожидаем.Что(КоличествоВхождений(ТекстВывода, "   duplicate_leaf (dev)")).Равно(1);
	Ожидаем.Что(ТекстВывода).Содержит("цепочка:     duplicate_parent -> duplicate_leaf");

КонецПроцедуры

Функция ОжидаемыйВыводРезультатаАнализа()
	
	ОжидаемыйВывод = Новый Структура("Часть1, Часть2, Часть3");

	ОжидаемыйВывод.Часть1 = 
	"Найдено проблем: 15
	|  6 отсутствуют в манифесте
	|  4 не используются
	|  3 не установлены
	|  2 конфликта версий
	|
	|[1] Отсутствуют в манифесте
	|
	|   missing_manifests_present_src
	|      └─ %1\src\Классы\Класс1.os
	|   missing_manifests_present_src_tests
	|      ├─ %1\src\Классы\Класс1.os
	|      └─ %1\src\Классы\Класс2.os
	|   missing_manifests_present_src_tests (dev)
	|      └─ %1\tests\Тесты.os
	|   missing_manifests_present_tests (dev)
	|      └─ %1\tests\Тесты.os
	|   present_in_dev_src_missing_tests
	|      └─ %1\src\Классы\Класс1.os
	|   present_in_dev_src_tests
	|      └─ %1\src\Классы\Класс1.os
	|
	|[2] Объявлены, но не используются
	|
	|   present_in_dev_missing_src_tests (dev)
	|   present_in_dev_src_missing_tests (dev)
	|   present_in_prod_missing_src_tests
	|   present_in_prod_tests_missing_src
	|
	|[3] Не установлены
	|
	|   present_in_dev_missing_src_tests (dev)
	|   present_in_dev_tests_missing_src (dev)
	|   present_in_prod_missing_src_tests
	|
	|[4] Несоответствие версий";

	ОжидаемыйВывод.Часть2 = 
	"   present_in_dev_src_tests (dev)
	|     установлена: 1.0.0
	|     требуется:   >=0.1.0,<=0.9.0
	|     путь:        %1\oscript_modules\present_in_dev_src_tests
	|
	|   present_in_prod_tests_missing_src
	|     установлена: 1.0.0
	|     требуется:   >=1.1.0
	|     путь:        %1\oscript_modules\present_in_prod_tests_missing_src";

	ОжидаемыйВывод.Часть3 = "Обнаружены проблемы с зависимостями.";

	ПодготовитьОжидаемыйВывод(ОжидаемыйВывод.Часть1);
	ПодготовитьОжидаемыйВывод(ОжидаемыйВывод.Часть2);

	Возврат ОжидаемыйВывод;

КонецФункции

Функция КоличествоВхождений(Текст, Подстрока)

	Количество = 0;
	Позиция = СтрНайти(Текст, Подстрока);

	Пока Позиция > 0 Цикл
		Количество = Количество + 1;
		СледующаяПозиция = Позиция + СтрДлина(Подстрока);
		ОстатокТекста = Сред(Текст, СледующаяПозиция);
		ПозицияВОстатке = СтрНайти(ОстатокТекста, Подстрока);

		Если ПозицияВОстатке = 0 Тогда
			Прервать;
		КонецЕсли;

		Позиция = СледующаяПозиция + ПозицияВОстатке - 1;
	КонецЦикла;

	Возврат Количество;

КонецФункции

Процедура ПодготовитьОжидаемыйВывод(ОжидаемыйВывод)

	ОжидаемыйВывод = СтрЗаменить(ОжидаемыйВывод, "\", ПолучитьРазделительПути());
	ОжидаемыйВывод = СтрШаблон(ОжидаемыйВывод, ФС.ПолныйПуть("./tests/fixtures/ПроектДляАнализа"));

КонецПроцедуры
