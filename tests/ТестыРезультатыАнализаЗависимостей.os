// BSLLS:LineLength-off
// BSLLS:DuplicateStringLiteral-off

#Использовать "helpers"

&Тест
Процедура ТестДолжен_СчитатьПроблемыИзВсехТаблиц() Экспорт

	// Подготовка
	Результат = Новый РезультатыАнализаЗависимостей();

	ДобавитьПакет(Результат.ОтсутствующиеВМанифестеПакеты, "missing_manifest");
	ДобавитьПакет(Результат.НеиспользуемыеПакеты, "unused");
	ДобавитьПакет(Результат.НеустановленныеПакеты, "not_installed");
	ДобавитьКонфликтВерсий(Результат.КонфликтыВерсийУстановленныхПакетов, "direct_conflict");
	ДобавитьТранзитивныйКонфликт(Результат.КонфликтыТранзитивныхЗависимостей, "shared");

	// Проверка
	Ожидаем.Что(Результат.ЕстьПроблемы()).ЭтоИстина();
	Ожидаем.Что(Результат.КоличествоПроблем()).Равно(5);

КонецПроцедуры

&Тест
Процедура ТестДолжен_ИсключатьПроблемыИзВсехТаблицПоИмени() Экспорт

	// Подготовка
	Результат = Новый РезультатыАнализаЗависимостей();

	ДобавитьПакет(Результат.ОтсутствующиеВМанифестеПакеты, "shared");
	ДобавитьПакет(Результат.НеиспользуемыеПакеты, "shared");
	ДобавитьПакет(Результат.НеустановленныеПакеты, "shared");
	ДобавитьКонфликтВерсий(Результат.КонфликтыВерсийУстановленныхПакетов, "shared");
	ДобавитьТранзитивныйКонфликт(Результат.КонфликтыТранзитивныхЗависимостей, "shared");

	// Действие
	Результат.ИсключитьПоИмени("shared");

	// Проверка
	Ожидаем.Что(Результат.КоличествоПроблем()).Равно(0);

КонецПроцедуры

Процедура ДобавитьПакет(Таблица, ИмяПакета)

	СтрокаТаблицы = Таблица.Добавить();
	СтрокаТаблицы.ИмяПакета = ИмяПакета;
	СтрокаТаблицы.ДляРазработки = Ложь;

КонецПроцедуры

Процедура ДобавитьКонфликтВерсий(Таблица, ИмяПакета)

	СтрокаТаблицы = Таблица.Добавить();
	СтрокаТаблицы.ИмяПакета = ИмяПакета;
	СтрокаТаблицы.ДляРазработки = Ложь;
	СтрокаТаблицы.ТребуемаяВерсия = ">=2.0.0";
	СтрокаТаблицы.УстановленнаяВерсия = "1.0.0";
	СтрокаТаблицы.Каталог = "./oscript_modules/" + ИмяПакета;

КонецПроцедуры

Процедура ДобавитьТранзитивныйКонфликт(Таблица, ИмяПакета)

	СтрокаТаблицы = Таблица.Добавить();
	СтрокаТаблицы.ИмяПакета = ИмяПакета;
	СтрокаТаблицы.ДляРазработки = Ложь;
	СтрокаТаблицы.ТипКонфликта = ТипыКонфликтовЗависимостей.УстановленнаяВерсияНеСоответствуетТребованию;
	СтрокаТаблицы.ИсточникТребования = "root_a";
	СтрокаТаблицы.ТребуемаяВерсия = ">=2.0.0";
	СтрокаТаблицы.УстановленнаяВерсия = "1.0.0";
	СтрокаТаблицы.ЦепочкаЗависимостей = "root_a -> shared";

КонецПроцедуры
